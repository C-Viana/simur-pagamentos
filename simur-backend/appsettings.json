{
  "Logging": {
    "LogLevel": {
      "Default": "Debug"
    }
  },
  "AllowedHosts": "*",
  "DatabaseConnectionString": {
    "MongoDB": {
      "URI": "mongodb://localhost:27018/?directConnection=true&replicaSet=rs0",
      "DbName": "simurdb",
      "RetryWrites": true,
      "RetryReads": true
    }
  },
  "MessageBroker": {
    "RabbitMQ": {
      "Hostname": "localhost",
      "Port": 5672,
      "Username": "",
      "Password": "",
      "ConnectionName": "simur-payments-service",
      "Publisher": {
        "Exchange": "payments",
        "Queue": "ready.payments",
        "RoutingKey": "simur.ready.payments"
      },
      "Consumer": {
        "Exchange": "payments",
        "Queue": "updated.payments",
        "RoutingKey": "simur.updated.payments"
      },
      "DeadLetters": {
        "Exchange": "payments.dlx",
        "Queue": "failed.payments",
        "RoutingKey": "simur.failed.payments"
      }
    }
  },
  "AuthConfigurations": {
    "Audience": "ExampleAudience",
    "Issuer": "ExempleIssuer",
    "RefreshLifetimeMinutes": 20,
    "TokenLifetimeMinutes": 10
  }
}
